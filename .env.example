# Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git — it is gitignored.
#
# Get values from:
#   - Anthropic API key: https://console.anthropic.com
#   - Other services: see docs/dev.md for setup instructions

# ── AI ────────────────────────────────────────────────────────────────────────
# Required for Claude-powered features
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite: path to the database file (relative to project root)
# DATABASE_URL=data/app.db

# PostgreSQL: connection string
# DATABASE_URL=postgresql://user:password@localhost:5432/myapp

# ── Server ────────────────────────────────────────────────────────────────────
# Port the backend API listens on (default: 8000)
# PORT=8000

# Environment: development | test | production
# NODE_ENV=development

# ── Auth / Security ───────────────────────────────────────────────────────────
# Secret key for signing JWTs or sessions (use a long random string)
# SECRET_KEY=replace-with-at-least-32-random-characters

# ── External APIs ─────────────────────────────────────────────────────────────
# Add your external service credentials here
# STRIPE_SECRET_KEY=sk_test_...
# SENDGRID_API_KEY=SG....
# GOOGLE_MAPS_API_KEY=AIza...

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Toggle features without code deploys
# ENABLE_BETA_FEATURES=false
# RATE_LIMIT_RPM=100
